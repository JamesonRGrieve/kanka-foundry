pnpm exec lint-staged --hide-unstaged

# Biome diagnostics ratchet: total (errors+warnings) cannot rise.
echo "[pre-commit] running biome ratchet…"
pnpm -s biome:ratchet

# Main typecheck ratchet: per-TS-code error counts under tsconfig.json cannot rise.
# Auto-flips to hard gate (must be zero) once each code reaches 0.
echo "[pre-commit] running typecheck ratchet…"
pnpm -s typecheck:ratchet

# ESLint warning ratchet: warning count cannot rise; errors never allowed.
echo "[pre-commit] running eslint ratchet…"
pnpm -s lint:ratchet

# Per-rule TS-strictness ratchet: per-directory `any`/`as any`/`@ts-expect-error`/
# `@ts-ignore` counts cannot rise. Auto-flips to strict at 0.
echo "[pre-commit] running ts coverage ratchet…"
pnpm -s ts:ratchet

# Strict-flag tsc ratchet: tsc --noEmit -p tsconfig.strict.json per-TS-code
# counts cannot rise. Each code auto-flips to strict at 0.
echo "[pre-commit] running strict-flag tsc ratchet…"
pnpm -s strict:ratchet

# type-coverage ratchet: inferred-any count under --strict cannot grow.
# Auto-flips to 100%-strict on ceiling.
echo "[pre-commit] running type-coverage ratchet…"
pnpm -s type-coverage:ratchet

# knip ratchet: unused files/exports/types/deps per-category cannot rise.
echo "[pre-commit] running knip ratchet…"
pnpm -s knip:ratchet

# dependency-cruiser ratchet: per-rule architecture violation counts cannot
# rise; auto-flips each rule to strict at 0.
echo "[pre-commit] running deps ratchet…"
pnpm -s deps:ratchet

# i18n consistency: en.yml (reference langpack) must parse. de/it/pt_BR are
# Weblate-managed, so their missing/extra keys are warnings only, never a fail.
echo "[pre-commit] running i18n check…"
pnpm -s i18n:check

# DRY-TODO ratchet: TODO(dry) marker count cannot rise.
echo "[pre-commit] running dry-todo ratchet…"
pnpm -s dry-todo:ratchet

# CSS-coverage ratchet: raw CSS rule count cannot rise (Tailwind direction).
echo "[pre-commit] running css ratchet…"
pnpm -s css:ratchet

# !important ratchet: count across CSS files cannot rise.
echo "[pre-commit] running important ratchet…"
pnpm -s important:ratchet

# theme guard: hardcoded hex color count cannot rise.
echo "[pre-commit] running theme ratchet…"
pnpm -s theme:ratchet

# animation guard: raw animation: declaration count cannot rise.
echo "[pre-commit] running animation ratchet…"
pnpm -s animation:ratchet

# Lockfile validator: every resolution URL must point at an allow-listed host.
echo "[pre-commit] running lockfile-validate…"
pnpm -s lockfile:validate

echo "[pre-commit] running Vitest…"
pnpm -s test
