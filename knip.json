{
    "$schema": "https://unpkg.com/knip@6/schema.json",
    "entry": [
        "src/index.ts",
        "src/index.js",
        "src/setupTests.ts",
        "scripts/*.mjs",
        "vite.config.ts",
        "playwright.foundry.config.ts",
        "tests/e2e/**/*.ts"
    ],
    "project": [
        "src/**/*.ts",
        "build/**/*.ts",
        "tests/e2e/**/*.ts"
    ],
    "ignore": [
        "src/foundryTypes.d.ts",
        "src/globalTypes.d.ts",
        "dist/**"
    ],
    "ignoreBinaries": [
        "biome",
        "knip",
        "type-coverage"
    ],
    "ignoreDependencies": [
        "tailwindcss",
        "@types/jquery"
    ]
}
