{
    "$schema": "https://biomejs.dev/schemas/2.3.2/schema.json",
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "suspicious": {
                "noRedeclare": "off",
                "noExplicitAny": "warn"
            },
            "complexity": {
                "noThisInStatic": "off"
            }
        },
        "includes": [
            "**",
            "!**/node_modules",
            "!**/dist",
            "!**/build",
            "!**/coverage",
            "!**/*.test.ts",
            "!**/*.test.js",
            "!**/*.spec.ts",
            "!**/*.spec.js",
            "!**/src/styles.css"
        ]
    },
    "formatter": {
        "enabled": false,
        "indentWidth": 4,
        "indentStyle": "space",
        "lineWidth": 120
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single"
        }
    }
}
