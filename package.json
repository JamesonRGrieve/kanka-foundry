{
    "private": true,
    "name": "kanka-foundry",
    "version": "6.0.2",
    "packageManager": "pnpm@10.32.1",
    "description": "",
    "repository": "https://github.com/eXaminator/kanka-foundry",
    "type": "module",
    "scripts": {
        "build": "vite build",
        "start": "NODE_ENV=development vite",
        "check": "pnpm check:types && pnpm check:lint && pnpm lint:biome",
        "check:types": "tsc --noEmit",
        "check:lint": "eslint src/ --ext .ts",
        "lint": "eslint src/ --ext .ts",
        "lint:fix": "eslint src/ --ext .ts --fix",
        "lint:biome": "biome lint src/",
        "typecheck": "tsc --noEmit",
        "release": "semantic-release",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "test:coverage": "vitest run --coverage",
        "prepare": "husky",
        "lint:ratchet": "node scripts/lint-ratchet.mjs",
        "lint:ratchet:update": "node scripts/lint-ratchet.mjs --update",
        "biome:ratchet": "node scripts/biome-ratchet.mjs",
        "biome:ratchet:update": "node scripts/biome-ratchet.mjs --update",
        "ts:coverage": "node scripts/ts-coverage.mjs",
        "ts:ratchet": "node scripts/ts-ratchet.mjs",
        "ts:ratchet:update": "node scripts/ts-ratchet.mjs --update",
        "strict:coverage": "node scripts/strict-coverage.mjs",
        "strict:ratchet": "node scripts/strict-ratchet.mjs",
        "strict:ratchet:update": "node scripts/strict-ratchet.mjs --update",
        "typecheck:ratchet": "node scripts/strict-ratchet.mjs --config tsconfig.json --baseline .tsc-baseline --report .tsc-coverage.json --label typecheck-ratchet",
        "typecheck:ratchet:update": "node scripts/strict-ratchet.mjs --config tsconfig.json --baseline .tsc-baseline --report .tsc-coverage.json --label typecheck-ratchet --update",
        "type-coverage": "type-coverage --strict",
        "type-coverage:ratchet": "node scripts/type-coverage-ratchet.mjs",
        "type-coverage:ratchet:update": "node scripts/type-coverage-ratchet.mjs --update",
        "knip": "knip",
        "knip:ratchet": "node scripts/knip-ratchet.mjs",
        "knip:ratchet:update": "node scripts/knip-ratchet.mjs --update",
        "lockfile:validate": "node scripts/lockfile-validate.mjs",
        "deps:check": "depcruise --config .dependency-cruiser.cjs src",
        "deps:ratchet": "node scripts/depcruise-ratchet.mjs",
        "deps:ratchet:update": "node scripts/depcruise-ratchet.mjs --update",
        "i18n:check": "node scripts/i18n-check.mjs",
        "dry-todo:coverage": "node scripts/dry-todo-ratchet.mjs --list",
        "dry-todo:ratchet": "node scripts/dry-todo-ratchet.mjs",
        "dry-todo:ratchet:update": "node scripts/dry-todo-ratchet.mjs --update",
        "css:coverage": "node scripts/css-coverage.mjs",
        "css:ratchet": "node scripts/css-ratchet.mjs",
        "css:ratchet:update": "node scripts/css-ratchet.mjs --update",
        "important:ratchet": "node scripts/important-ratchet.mjs",
        "important:ratchet:update": "node scripts/important-ratchet.mjs --update",
        "theme:ratchet": "node scripts/theme-ratchet.mjs",
        "theme:ratchet:update": "node scripts/theme-ratchet.mjs --update",
        "animation:ratchet": "node scripts/animation-ratchet.mjs",
        "animation:ratchet:update": "node scripts/animation-ratchet.mjs --update"
    },
    "lint-staged": {
        "src/**/*.ts": [
            "eslint --fix --quiet",
            "biome lint --fix",
            "prettier --write"
        ],
        "src/**/*.json": [
            "prettier --write"
        ]
    },
    "author": "Steven Weingärtner",
    "license": "MIT",
    "devDependencies": {
        "@biomejs/biome": "^2.4.8",
        "@semantic-release/changelog": "^6.0.0",
        "@semantic-release/git": "^10.0.0",
        "@types/jquery": "^3.5.34",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^22.19.15",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "@typhonjs-fvtt/eslint-config-foundry.js": "0.8.0",
        "@vitest/coverage-v8": "^4.1.0",
        "dependency-cruiser": "^17.4.2",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "9.1.2",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prettier": "5.5.5",
        "flat": "^6.0.1",
        "fvtt-types": "github:League-of-Foundry-Developers/foundry-vtt-types#main",
        "handlebars": "^4.7.7",
        "husky": "^9.1.7",
        "js-yaml": "^4.1.1",
        "knip": "^6.0.0",
        "lint-staged": "^16.4.0",
        "mockdate": "^3.0.5",
        "prettier": "^3.8.1",
        "sass": "^1.98.0",
        "semantic-release": "^25.0.3",
        "semantic-release-replace-plugin": "^1.2.7",
        "type-coverage": "^2.29.0",
        "typescript": "^5.8.3",
        "vite": "^8.0.1",
        "vitest": "^4.1.0",
        "yaml": "^2.9.0"
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.2.2",
        "jwt-decode": "^4.0.0",
        "tailwindcss": "^4.2.2"
    }
}
